# ============================================================
# CERTIFICACIÓN A · SISTEMA — Variables de entorno
# Copiar este archivo como .env y completar con valores reales
# NUNCA subir .env a git ni compartirlo
# ============================================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development
# development | production

# --- SUPABASE ---
SUPABASE_URL=https://[TU-PROYECTO].supabase.co
SUPABASE_ANON_KEY=[ANON_KEY_DE_SUPABASE]
SUPABASE_SERVICE_KEY=[SERVICE_ROLE_KEY_DE_SUPABASE]
# Service key: solo backend, nunca exponer en frontend

